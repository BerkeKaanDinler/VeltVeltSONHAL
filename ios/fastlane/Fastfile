# VELT iOS — Fastlane
#
# Run from project root:
#   cd ios && bundle exec fastlane beta
#   cd ios && bundle exec fastlane release
#
# Requirements (one-time):
#   gem install bundler
#   cd ios && bundle init && bundle add fastlane
#
# Env vars (.env or shell):
#   APP_STORE_CONNECT_API_KEY_PATH     path to AuthKey_*.p8
#   APP_STORE_CONNECT_API_KEY_ID       Key ID from App Store Connect → Users → Keys
#   APP_STORE_CONNECT_API_ISSUER_ID    Issuer ID from same page
#   MATCH_PASSWORD                     (if using match for signing)
#   SENTRY_DSN                         optional — passed to --dart-define
#   SUPABASE_URL / SUPABASE_ANON_KEY   optional
#   REVENUECAT_APPLE_KEY               optional

default_platform(:ios)

platform :ios do
  desc "Build & upload a TestFlight beta"
  lane :beta do
    setup_ci if is_ci

    # Authenticate with App Store Connect API key
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_API_KEY_PATH"],
      duration: 1200,
      in_house: false,
    )

    # Auto bump build number using latest TestFlight build
    increment_build_number(
      xcodeproj: "Runner.xcodeproj",
      build_number: latest_testflight_build_number(
        api_key: api_key,
        app_identifier: "com.veltfitness.app",
      ) + 1
    )

    # Build with Flutter — passing --dart-define for env-bound services
    sh(
      "cd ../.. && flutter build ipa --release " \
        "--dart-define=SENTRY_DSN=#{ENV['SENTRY_DSN'] || ''} " \
        "--dart-define=SUPABASE_URL=#{ENV['SUPABASE_URL'] || ''} " \
        "--dart-define=SUPABASE_ANON_KEY=#{ENV['SUPABASE_ANON_KEY'] || ''} " \
        "--dart-define=REVENUECAT_APPLE_KEY=#{ENV['REVENUECAT_APPLE_KEY'] || ''}"
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: "../build/ios/ipa/velt.ipa",
      skip_waiting_for_build_processing: true,
      changelog: read_changelog,
      distribute_external: false,
    )
  end

  desc "Build & upload a production release to App Store Connect"
  lane :release do
    setup_ci if is_ci

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_API_KEY_PATH"],
    )

    sh(
      "cd ../.. && flutter build ipa --release " \
        "--dart-define=SENTRY_DSN=#{ENV['SENTRY_DSN'] || ''} " \
        "--dart-define=SUPABASE_URL=#{ENV['SUPABASE_URL'] || ''} " \
        "--dart-define=SUPABASE_ANON_KEY=#{ENV['SUPABASE_ANON_KEY'] || ''} " \
        "--dart-define=REVENUECAT_APPLE_KEY=#{ENV['REVENUECAT_APPLE_KEY'] || ''}"
    )

    deliver(
      api_key: api_key,
      ipa: "../build/ios/ipa/velt.ipa",
      submit_for_review: false, # set true after first manual review
      automatic_release: false,
      force: true,
      skip_screenshots: true,
      skip_metadata: false,
      metadata_path: "./fastlane/metadata",
    )
  end
end

def read_changelog
  path = File.expand_path("../../store/whatsnew_en.txt", __dir__)
  File.exist?(path) ? File.read(path).strip : "Routine improvements and bug fixes."
end
